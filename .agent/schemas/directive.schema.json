{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/directive.schema.json",
  "title": "Governance Directive",
  "type": "object",
  "required": [
    "id",
    "type",
    "source",
    "status",
    "priority",
    "scope",
    "content",
    "enforcement"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^D-[0-9]{4,}$"
    },
    "type": {
      "type": "string",
      "enum": [
        "content_requirement",
        "style_constraint",
        "risk_policy",
        "evidence_policy",
        "terminology_rule",
        "formatting_rule",
        "assembly_rule",
        "workflow_rule",
        "scope_constraint",
        "other"
      ]
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "active",
        "paused",
        "superseded",
        "retired"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ]
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "applies_to": {
      "$ref": "#/$defs/appliesTo"
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string"
    },
    "enforcement": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "channel",
          "text"
        ],
        "properties": {
          "channel": {
            "type": "string",
            "enum": [
              "task_objective",
              "task_constraint",
              "acceptance_criterion",
              "context_pack_note",
              "reviewer_check",
              "validator_rule",
              "assembler_rule",
              "human_review_note"
            ]
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        },
        "additionalProperties": true
      }
    },
    "conflict_policy": {
      "type": "string",
      "enum": [
        "raise_escalation",
        "block_until_decided",
        "chief_editor_decides",
        "prefer_requirement",
        "prefer_directive"
      ],
      "default": "raise_escalation"
    },
    "related_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_decisions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^DEC-[0-9]{4,}$"
      }
    },
    "related_escalations": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^E-[0-9]{4,}$"
      }
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^D-[0-9]{4,}$"
      }
    },
    "superseded_by": {
      "type": "string",
      "pattern": "^D-[0-9]{4,}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true,
  "$defs": {
    "role": {
      "type": "string",
      "enum": [
        "chief-editor",
        "requirement-analyst",
        "document-architect",
        "section-writer",
        "reviewer",
        "asset-director",
        "assembler",
        "orchestrator",
        "user"
      ]
    },
    "source": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "chief-editor",
            "requirement-analyst",
            "document-architect",
            "section-writer",
            "reviewer",
            "asset-director",
            "assembler",
            "orchestrator",
            "system"
          ]
        },
        "name": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "scope": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "document": {
          "type": "boolean"
        },
        "chapters": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^T-[0-9]{4,}$"
          }
        },
        "assets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "appliesTo": {
      "type": "object",
      "properties": {
        "roles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/role"
          }
        },
        "task_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "planning",
              "context_building",
              "writing",
              "review",
              "revision",
              "assembly",
              "release"
            ]
          }
        }
      },
      "additionalProperties": true
    }
  }
}
