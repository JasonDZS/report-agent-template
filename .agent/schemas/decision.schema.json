{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/decision.schema.json",
  "title": "Governance Decision",
  "type": "object",
  "required": [
    "id",
    "status",
    "authority",
    "question",
    "scope",
    "options"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^DEC-[0-9]{4,}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "active",
        "superseded",
        "revoked"
      ]
    },
    "authority": {
      "type": "string",
      "enum": [
        "user",
        "chief-editor",
        "orchestrator-policy",
        "system-policy"
      ]
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "source_escalation": {
      "type": "string",
      "pattern": "^E-[0-9]{4,}$"
    },
    "source_directives": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^D-[0-9]{4,}$"
      }
    },
    "source_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "risk": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "impact": {
            "type": "string"
          },
          "requires_evidence": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    },
    "chosen_option_id": {
      "type": "string"
    },
    "resolution": {
      "type": "object",
      "required": [
        "summary"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string"
        },
        "downstream_directives": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^D-[0-9]{4,}$"
          }
        },
        "implementation_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "decided_by": {
      "$ref": "#/$defs/decisionMaker"
    },
    "decided_at": {
      "type": "string",
      "format": "date-time"
    },
    "effective_from": {
      "type": "string",
      "format": "date-time"
    },
    "review_after": {
      "type": "string",
      "format": "date-time"
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^DEC-[0-9]{4,}$"
      }
    },
    "superseded_by": {
      "type": "string",
      "pattern": "^DEC-[0-9]{4,}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "active"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "options",
          "chosen_option_id",
          "resolution",
          "decided_by",
          "decided_at"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "superseded",
              "revoked"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "options",
          "resolution",
          "decided_by",
          "decided_at"
        ]
      }
    }
  ],
  "additionalProperties": true,
  "$defs": {
    "scope": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "document": {
          "type": "boolean"
        },
        "chapters": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^T-[0-9]{4,}$"
          }
        },
        "assets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "decisionMaker": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "chief-editor",
            "orchestrator",
            "system"
          ]
        },
        "name": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  }
}
