{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/task.schema.json",
  "title": "Agent Task",
  "type": "object",
  "required": ["id", "type", "role", "status", "objective", "allowed_inputs", "allowed_outputs", "acceptance_criteria"],
  "properties": {
    "id": { "type": "string", "pattern": "^T-[0-9]{4,}$" },
    "type": {
      "type": "string",
      "enum": [
        "requirement_extract",
        "outline_plan",
        "section_write",
        "section_revision",
        "table_build",
        "image_brief",
        "review",
        "assembly",
        "governance"
      ]
    },
    "role": {
      "type": "string",
      "enum": [
        "chief-editor",
        "requirement-analyst",
        "document-architect",
        "section-writer",
        "reviewer",
        "asset-director",
        "assembler"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "assigned",
        "running",
        "committed",
        "machine_validated",
        "review_requested",
        "needs_revision",
        "approved",
        "merged",
        "failed"
      ]
    },
    "branch": { "type": "string" },
    "base_branch": { "type": "string", "default": "main" },
    "worktree": { "type": "string" },
    "objective": { "type": "string", "minLength": 1 },
    "background": { "type": "string" },
    "requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_inputs": {
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "string" }
        },
        {
          "type": "object",
          "required": ["required"],
          "properties": {
            "required": {
              "type": "array",
              "items": { "type": "string" }
            },
            "searchable": {
              "type": "array",
              "items": { "type": "string" }
            },
            "restricted": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "allowed_outputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "evidence_policy": {
      "type": "object",
      "properties": {
        "start_with_context_pack": { "type": "boolean", "default": true },
        "record_searchable_sources": { "type": "boolean", "default": true },
        "raw_sources_require_explicit_authorization": { "type": "boolean", "default": true }
      },
      "additionalProperties": true
    },
    "human_review_required": { "type": "boolean", "default": true },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
