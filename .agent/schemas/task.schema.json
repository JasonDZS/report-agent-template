{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/task.schema.json",
  "title": "Agent Task",
  "type": "object",
  "required": ["id", "type", "role", "status", "objective", "allowed_inputs", "allowed_outputs", "acceptance_criteria"],
  "properties": {
    "id": { "$ref": "#/$defs/taskId" },
    "type": {
      "type": "string",
      "enum": [
        "requirement_extract",
        "outline_plan",
        "section_task_plan",
        "section_write",
        "section_revision",
        "table_build",
        "image_brief",
        "review",
        "assembly",
        "governance"
      ]
    },
    "role": {
      "type": "string",
      "enum": [
        "chief-editor",
        "requirement-analyst",
        "document-architect",
        "section-writer",
        "reviewer",
        "asset-director",
        "assembler"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "assigned",
        "running",
        "committed",
        "machine_validated",
        "review_requested",
        "blocked_pending_decision",
        "ready_to_continue",
        "needs_revision",
        "approved",
        "merged",
        "failed"
      ]
    },
    "branch": { "type": "string" },
    "base_branch": { "type": "string", "default": "main" },
    "worktree": { "type": "string" },
    "depends_on": {
      "type": "object",
      "properties": {
        "tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/taskId" }
        },
        "directives": {
          "type": "array",
          "items": { "$ref": "#/$defs/directiveId" }
        },
        "decisions": {
          "type": "array",
          "items": { "$ref": "#/$defs/decisionId" }
        },
        "resolved_escalations": {
          "type": "array",
          "items": { "$ref": "#/$defs/escalationId" }
        },
        "approvals": {
          "type": "array",
          "items": { "$ref": "#/$defs/approvalId" }
        }
      },
      "additionalProperties": true
    },
    "blocks": {
      "type": "array",
      "items": { "$ref": "#/$defs/taskId" }
    },
    "continues_from": { "$ref": "#/$defs/taskId" },
    "blocked_by_escalation": { "$ref": "#/$defs/escalationId" },
    "directive_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/directiveId" }
    },
    "decision_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/decisionId" }
    },
    "escalation_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/escalationId" }
    },
    "approval_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/approvalId" }
    },
    "continuation_policy": {
      "type": "object",
      "properties": {
        "session_strategy": {
          "type": "string",
          "enum": ["new_session", "resume_if_available", "resume_required"],
          "default": "new_session"
        },
        "preserve_worktree": { "type": "boolean", "default": true },
        "reuse_branch": { "type": "boolean", "default": false },
        "resume_session_ref": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "objective": { "type": "string", "minLength": 1 },
    "background": { "type": "string" },
    "requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_inputs": {
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "string" }
        },
        {
          "type": "object",
          "required": ["required"],
          "properties": {
            "required": {
              "type": "array",
              "items": { "type": "string" }
            },
            "searchable": {
              "type": "array",
              "items": { "type": "string" }
            },
            "restricted": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "allowed_outputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "evidence_policy": {
      "type": "object",
      "properties": {
        "start_with_context_pack": { "type": "boolean", "default": true },
        "record_searchable_sources": { "type": "boolean", "default": true },
        "raw_sources_require_explicit_authorization": { "type": "boolean", "default": true }
      },
      "additionalProperties": true
    },
    "human_review_required": { "type": "boolean", "default": true },
    "notes": { "type": "string" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "const": "blocked_pending_decision" }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["blocked_by_escalation"]
      }
    },
    {
      "if": {
        "required": ["continues_from"]
      },
      "then": {
        "required": ["continuation_policy"]
      }
    }
  ],
  "additionalProperties": true,
  "$defs": {
    "taskId": { "type": "string", "pattern": "^T-[0-9]{4,}$" },
    "directiveId": { "type": "string", "pattern": "^D-[0-9]{4,}$" },
    "decisionId": { "type": "string", "pattern": "^DEC-[0-9]{4,}$" },
    "escalationId": { "type": "string", "pattern": "^E-[0-9]{4,}$" },
    "approvalId": { "type": "string", "pattern": "^APR-[0-9]{4,}$" }
  }
}
