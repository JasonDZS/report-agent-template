{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/section-meta.schema.json",
  "title": "Section Metadata",
  "type": "object",
  "required": ["section_id", "title", "status", "covered_requirements"],
  "properties": {
    "section_id": { "type": "string" },
    "title": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "drafting",
        "drafted",
        "machine_reviewed",
        "human_review_required",
        "approved",
        "needs_revision",
        "locked",
        "assembled"
      ]
    },
    "author_task": { "type": "string" },
    "covered_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risk_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assets": {
      "type": "object",
      "properties": {
        "tables": {
          "type": "array",
          "items": { "type": "string" }
        },
        "images": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "review_status": { "type": "string" }
  },
  "additionalProperties": true
}
