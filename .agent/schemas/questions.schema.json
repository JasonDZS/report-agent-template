{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/questions.schema.json",
  "title": "Run Questions",
  "type": "object",
  "required": [
    "task_id",
    "status",
    "questions"
  ],
  "properties": {
    "task_id": {
      "$ref": "#/$defs/taskId"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "triaged",
        "escalated",
        "resolved"
      ]
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "severity",
          "blocking",
          "question",
          "why_it_matters"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^Q-[0-9]{4,}$"
          },
          "type": {
            "type": "string",
            "enum": [
              "decision_required",
              "clarification",
              "conflict",
              "risk",
              "evidence_gap",
              "other"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "blocking": {
            "type": "boolean"
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "why_it_matters": {
            "type": "string",
            "minLength": 1
          },
          "recommendation": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "label"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "risk": {
                  "type": "string",
                  "enum": [
                    "critical",
                    "high",
                    "medium",
                    "low"
                  ]
                },
                "impact": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          },
          "recommended_option_id": {
            "type": "string"
          },
          "related_requirements": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "related_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "converted_to_escalation": {
            "$ref": "#/$defs/escalationId"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "taskId": {
      "type": "string",
      "pattern": "^T-[0-9]{4,}$"
    },
    "escalationId": {
      "type": "string",
      "pattern": "^E-[0-9]{4,}$"
    }
  }
}
