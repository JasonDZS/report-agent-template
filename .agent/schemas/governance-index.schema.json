{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/governance-index.schema.json",
  "title": "Governance Index",
  "type": "object",
  "required": [
    "kind",
    "updated_at",
    "generated_by",
    "items"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "active_directives",
        "pending_escalations"
      ]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generated_by": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "scope": {
            "type": "object"
          },
          "blocks": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^T-[0-9]{4,}$"
            }
          },
          "file": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
