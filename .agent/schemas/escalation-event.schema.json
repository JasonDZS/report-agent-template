{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/escalation-event.schema.json",
  "title": "Escalation Event",
  "type": "object",
  "required": [
    "id",
    "type",
    "status",
    "severity",
    "title",
    "summary",
    "raised_by",
    "blocking",
    "context"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^E-[0-9]{4,}$"
    },
    "type": {
      "type": "string",
      "enum": [
        "decision_required",
        "conflict",
        "evidence_gap",
        "risk",
        "review_summary",
        "blocked"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "in_triage",
        "pending_human",
        "resolved",
        "converted_to_decision",
        "dismissed"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "info"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "raised_by": {
      "$ref": "#/$defs/source"
    },
    "blocking": {
      "type": "boolean"
    },
    "context": {
      "$ref": "#/$defs/eventContext"
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "risk": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "impact": {
            "type": "string"
          },
          "requires_user_input": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    },
    "recommended_option_id": {
      "type": "string"
    },
    "recommendation": {
      "type": "string"
    },
    "requested_response": {
      "type": "string"
    },
    "resolution": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string"
        },
        "resolved_by": {
          "$ref": "#/$defs/source"
        },
        "resolved_at": {
          "type": "string",
          "format": "date-time"
        },
        "decision_id": {
          "type": "string",
          "pattern": "^DEC-[0-9]{4,}$"
        },
        "dismissal_reason": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "decision_required"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "required": [
          "options",
          "requested_response"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "resolved",
              "converted_to_decision",
              "dismissed"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "resolution"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "converted_to_decision"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "resolution": {
            "required": [
              "decision_id"
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": true,
  "$defs": {
    "source": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "chief-editor",
            "requirement-analyst",
            "document-architect",
            "section-writer",
            "reviewer",
            "asset-director",
            "assembler",
            "orchestrator",
            "system"
          ]
        },
        "task_id": {
          "type": "string",
          "pattern": "^T-[0-9]{4,}$"
        },
        "name": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "eventContext": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "directives": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^D-[0-9]{4,}$"
          }
        },
        "decisions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^DEC-[0-9]{4,}$"
          }
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^T-[0-9]{4,}$"
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "review_findings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  }
}
